---

---

<div
  id="3d-popcorn"
  class="pointer-none: fixed top-0 left-0 z-0 h-screen w-full"
>
</div>

<script>
  import { initModel } from "../scripts/3dModel";
  import { onPageLoad } from "../scripts/utils";

  await onPageLoad(async () => {
    let config = {
      intro: {
        position: { x: 0, y: 0 },
        scale: 1,
      },
      "popcorn-showcase": {
        position: { x: 0, y: 0 },
        scale: 1.5,
      },
      features: {
        position: { x: 0.9, y: 0 },
        scale: 0.8,
      },
      examples: {
        position: { x: 0.9, y: 0 },
        scale: 0,
      },
    };

    const isMobile = window.innerWidth < 640;
    if (isMobile) {
      config = {
        intro: {
          position: { x: 0, y: 0 },
          scale: 0.3,
        },
        "popcorn-showcase": {
          position: { x: 0, y: 0 },
          scale: 0.7,
        },
        features: {
          position: { x: 0, y: 0 },
          scale: 0.3,
        },
        examples: {
          position: { x: 0, y: 0 },
          scale: 0,
        },
      };
    }

    await initModel({
      path: "/popcorn.glb",
      containerId: "3d-popcorn",
      sectionConfig: config,
    });
  });
</script>
