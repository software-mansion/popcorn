---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/Section.astro";
import LlvDemoLayout from "../../components/local-live-view/LlvDemoLayout.astro";
import { AssignsPanel } from "../../components/local-live-view/AssignsPanel";
import { LifecycleStrip } from "../../components/local-live-view/LifecycleStrip";
import { EventLog } from "../../components/local-live-view/EventLog";
import LlvCodePanel from "../../components/local-live-view/LlvCodePanel.astro";
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { createBlockTransformer } from "../../scripts/local-live-view/code-panel";
import type { CodeTab } from "../../components/local-live-view/LlvCodePanel.astro";
import "../../styles/demos/local-thermostat.css";

const libDir = path.resolve(
  fileURLToPath(import.meta.url),
  "../../../../..",
  "examples/local-lv-thermostat/local/lib",
);
const thermostatCode = fs
  .readFileSync(path.join(libDir, "thermostat_live.ex"), "utf8")
  .trim();
const clockCode = fs
  .readFileSync(path.join(libDir, "clock_live.ex"), "utf8")
  .trim();

const tabs: CodeTab[] = [
  {
    label: "ThermostatLive",
    id: "thermostat",
    code: thermostatCode,
    lang: "elixir",
  },
  { label: "ClockLive", id: "clock", code: clockCode, lang: "elixir" },
];
---

<Layout>
  <Section background="light">
    <header class="mb-4 text-center">
      <h1
        class="font-handjet text-brown-header mb-3 text-4xl font-bold md:text-5xl"
      >
        Local thermostat
      </h1>
      <p class="mx-auto mt-4 max-w-2xl leading-6">
        This example consists of two live view components powered by Popcorn. It
        allows them to work fully locally, without any server for updates.
      </p>
      <p class="mt-3">
        Temperature control demonstrates mouse events, the datetime control
        demonstrates use of timers.
      </p>
    </header>

    <LlvDemoLayout>
      <Fragment slot="left">
        <div class="demo-card">
          <div
            data-pop-view="ThermostatLivePresentation"
            id="ThermostatLivePresentation"
          >
          </div>
          <div
            data-pop-view="ClockLive"
            id="ClockLive"
            data-phx-session="session"
            class="clock-band"
          >
          </div>
        </div>

        <AssignsPanel client:load />
        <LifecycleStrip client:load />
        <EventLog client:load />
      </Fragment>

      <LlvCodePanel slot="right" tabs={tabs} />
    </LlvDemoLayout>
  </Section>
</Layout>


<script>
  import { Socket } from "phoenix";
  import { LiveSocket } from "phoenix_live_view";
  import { LLVEngine } from "local_live_view";
  import {
    $assigns,
    pushLog,
    type LogEntry,
    type PresentationPayload,
  } from "../../scripts/local-live-view/store";
  import {
    applyAssignsWithFlash,
    createAnimation,
    setCodeHighlight,
    highlightHtml,
  } from "../../scripts/local-live-view/animation";

  type ThermoCtx = {
    block: string;
    newAssigns: Record<string, unknown>;
  };

  const CODE_PANEL = "llv-code-body-0";
  const multiplier = 3;

  let logId = 0;
  let pendingAck = false;
  let llv: LLVEngine | null = null;

  const thermoAnimation = createAnimation<ThermoCtx>(
    [
      { delay: 0 },
      {
        delay: 180 * multiplier,
        onEnter: ({ block }) => setCodeHighlight(CODE_PANEL, block),
      },
      {
        delay: 900 * multiplier,
        onEnter: ({ newAssigns }) => {
          applyAssignsWithFlash(newAssigns);
          setCodeHighlight(CODE_PANEL, "render");
        },
      },
      {
        delay: 1300 * multiplier,
        onEnter: () => {
          pendingAck = false;
          highlightHtml("temperature", true);
          llv?.pushEvent("ThermostatLivePresentation", "llv_ack");
        },
      },
    ],
    {
      completeDelay: 1800 * multiplier,
      onComplete: () => {
        pendingAck = false;
        highlightHtml("temperature", false);
        setCodeHighlight(CODE_PANEL, null);
      },
      onCancel: ({ newAssigns }) => {
        // Fire ack immediately on cancel so spam clicks accumulate in Elixir's _pending.
        if (pendingAck) {
          applyAssignsWithFlash(newAssigns);
          llv?.pushEvent("ThermostatLivePresentation", "llv_ack");
        }
        pendingAck = false;
        highlightHtml("temperature", false);
        setCodeHighlight(CODE_PANEL, null);
      },
    },
  );

  function animate(
    block: string,
    eventName: string,
    newAssigns: Record<string, unknown>,
  ) {
    const result = Object.entries(newAssigns)
      .map(([k, v]) => `${k}: ${typeof v === "string" ? `"${v}"` : v}`)
      .join(", ");
    const entry: LogEntry = {
      id: ++logId,
      event: `handle_event("${eventName}")`,
      result,
    };
    pushLog(entry);

    thermoAnimation.run({ block, newAssigns });
    pendingAck = true;
  }

  function handlePresentation({ block, event, assigns }: PresentationPayload) {
    if (!block || event === "mount") {
      $assigns.set(assigns);
      return;
    }

    animate(block, event, assigns);
  }

  async function init() {
    const liveSocket = new LiveSocket("/live", Socket, { params: {} });

    llv = await LLVEngine.create(liveSocket, {
      Socket,
      bundlePaths: ["/wasm/local_thermostat.avm"],
      eventHandler: (name: string, payload: unknown) => {
        if (name === "llv_presentation") handlePresentation(payload as PresentationPayload);
      },
    });

    liveSocket.connect();
  }

  document.addEventListener("DOMContentLoaded", init);
  document.addEventListener("astro:page-load", init);
</script>
