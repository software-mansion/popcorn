diff --git a/erts/configure.ac b/erts/configure.ac
index 9ed8c5e398624b4ee4e752c0e32b2e87d22ea02d..924973cf2a2fed76f0a45e06a0d17e417d1095a4 100644
--- a/erts/configure.ac
+++ b/erts/configure.ac
@@ -522,8 +522,38 @@ dnl Special stuff regarding CFLAGS and details in the environment...
 dnl ---------------------------------------------------------------------
 
 dnl NOTE: CPPFLAGS will be included in CFLAGS at the end
+
+dnl ----------------------------------------------------------------------
+dnl Emscripten/WebAssembly detection
+dnl ----------------------------------------------------------------------
+EMSCRIPTEN=no
+case $host in
+    wasm32-*-emscripten*|wasm64-*-emscripten*)
+        EMSCRIPTEN=yes
+        AC_DEFINE(ERTS_EMSCRIPTEN, 1, [Define if targeting Emscripten/WebAssembly])
+        dnl Force disable features not supported on WASM
+        enable_jit=no
+        enable_sctp=no
+        if test "x$enable_kernel_poll" = "xunknown"; then
+            enable_kernel_poll=no
+        fi
+        dnl Override function detection for functions not in Emscripten
+        ac_cv_func_memrchr=no
+        ac_cv_func_mallopt=no
+        ac_cv_func_sbrk=no
+        ac_cv_func_brk=no
+        ac_cv_func_mremap=no
+        ac_cv_func_vsyslog=no
+        ac_cv_func_ppoll=no
+        AC_MSG_NOTICE([Configuring for Emscripten/WebAssembly])
+        AC_MSG_NOTICE([  JIT disabled (not supported on WASM)])
+        AC_MSG_NOTICE([  SCTP disabled (not supported on WASM)])
+        ;;
+esac
+AC_SUBST(EMSCRIPTEN)
+
 case $host_os in
-    linux*) CPPFLAGS="$CPPFLAGS -D_GNU_SOURCE";; 
+    linux*) CPPFLAGS="$CPPFLAGS -D_GNU_SOURCE";;
     aix*|os400*)
         # * _ALL_SOURCE: Required to get the winsize structure for TIOCSWINSZ.
         # * _LINUX_SOURCE_COMPAT: Not required, but makes some libc functions
@@ -535,6 +565,10 @@ case $host_os in
 	# -D_WIN32_WINNT=* from CPPFLAGS is saved in ETHR_DEFS.
 	CPPFLAGS="$CPPFLAGS -D_WIN32_WINNT=0x0600 -DWINVER=0x0600"
 	;;
+    emscripten*)
+	# Emscripten/WASM target
+	CPPFLAGS="$CPPFLAGS -DERTS_EMSCRIPTEN"
+	;;
     *)
 	;;
 esac
