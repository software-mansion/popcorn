diff --git a/xcomp/erl-xcomp-wasm32-emscripten.conf b/xcomp/erl-xcomp-wasm32-emscripten.conf
new file mode 100644
index 0000000000000000000000000000000000000000..d9d35a2f177b97c9b324e1a83dc19138e5d51541
--- /dev/null
+++ b/xcomp/erl-xcomp-wasm32-emscripten.conf
@@ -0,0 +1,113 @@
+## -*-shell-script-*-
+##
+## Cross compilation configuration for WebAssembly via Emscripten
+##
+## Usage:
+##   ./otp_build configure --xcomp-conf=xcomp/erl-xcomp-wasm32-emscripten.conf
+##
+## Or manually:
+##   emconfigure ./configure --host=wasm32-unknown-emscripten --build=$(./make/autoconf/config.guess) ...
+##
+
+## -- Variables for `otp_build' Only -------------------------------------------
+
+erl_xcomp_build=guess
+erl_xcomp_host=wasm32-unknown-emscripten
+
+erl_xcomp_configure_flags="--disable-jit \
+    --disable-sctp \
+    --disable-kernel-poll \
+    --without-common_test \
+    --without-asn1 \
+    --without-diameter \
+    --without-edoc \
+    --without-eldap \
+    --without-eunit \
+    --without-ftp \
+    --without-jinterface \
+    --without-reltool \
+    --without-snmp \
+    --without-tftp \
+    --without-tools \
+    --without-termcap \
+    --without-wx \
+    --without-debugger \
+    --without-dialyzer \
+    --without-et \
+    --without-megaco \
+    --without-observer \
+    --without-odbc \
+    --without-os_mon \
+    --without-parsetools \
+    --without-public_key \
+    --without-ssh \
+    --without-ssl \
+    --without-threadnames \
+    --without-javac \
+    --enable-builtin-zlib \
+    --disable-esock \
+    --disable-dynamic-ssl-lib"
+
+## -- Cross Compiler and Other Tools -------------------------------------------
+
+CC=emcc
+CXX=em++
+LD=emcc
+AR=emar
+RANLIB=emranlib
+
+## Compiler flags
+CFLAGS="-O2 -pthread -g"
+
+## Linker flags for Emscripten
+## Note: These are passed to emcc during linking
+LDFLAGS="-pthread \
+    -sUSE_PTHREADS=1 \
+    -sPTHREAD_POOL_SIZE=4 \
+    -sPROXY_TO_PTHREAD=1 \
+    -sENVIRONMENT=web,worker,node \
+    -sEXPORT_ES6=1 \
+    -sMODULARIZE=1 \
+    -sINITIAL_MEMORY=256MB \
+    -sALLOW_MEMORY_GROWTH=1 \
+    -sEXPORTED_RUNTIME_METHODS=FS,ENV,TTY,ccall,stringToNewUTF8,lengthBytesUTF8 \
+    -sEXPORTED_FUNCTIONS=['_main','_malloc','_free'] \
+    -sFORCE_FILESYSTEM=1 \
+    -sASSERTIONS=2 \
+    -sEMULATE_FUNCTION_POINTER_CASTS"
+
+## -- Cross System Root Locations ----------------------------------------------
+
+## Emscripten handles sysroot internally
+erl_xcomp_sysroot=
+
+## -- Optional Feature, and Bug Tests ------------------------------------------
+
+## These are values that cannot be determined by configure when cross-compiling.
+## We set them explicitly for WASM/Emscripten.
+
+## Endianness: WASM is little-endian
+erl_xcomp_bigendian=no
+
+## No clock_gettime for CPU time on WASM
+erl_xcomp_clock_gettime_cpu_time=no
+
+## getaddrinfo works in Emscripten (via proxy)
+erl_xcomp_getaddrinfo=no
+
+## No kqueue on WASM
+erl_xcomp_kqueue=no
+
+## No poll() - use select() instead
+erl_xcomp_poll=no
+
+## No reliable floating point exceptions
+erl_xcomp_reliable_fpe=no
+
+## posix_memalign works
+erl_xcomp_posix_memalign=yes
+
+## putenv stores a copy
+erl_xcomp_putenv_copy=yes
+
+## -----------------------------------------------------------------------------
