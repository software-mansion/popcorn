{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "lib": ["es2023", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@swmansion/popcorn-otp": ["../src/index.ts"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules", "../dist"]
}
