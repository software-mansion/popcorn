{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noUnusedLocals": true,
    "lib": ["es2023", "WebWorker", "DOM"],
    "types": ["node"],
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "dist",
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
}
